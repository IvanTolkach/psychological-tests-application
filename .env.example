# Database
POSTGRES_DB=psychologicaltestsdb
DB_HOST=postgres
DB_PORT=5432
DB_NAME=psychologicaltestsdb
DB_USER=postgres
DB_PASSWORD=change_me

# External ports
POSTGRES_EXTERNAL_PORT=5432
REDIS_EXTERNAL_PORT=6379
EUREKA_EXTERNAL_PORT=8761
USERS_SERVICE_EXTERNAL_PORT=8081
METHODOLOGIES_SERVICE_EXTERNAL_PORT=8082
TESTS_SERVICE_EXTERNAL_PORT=8083
ATTEMPTS_SERVICE_EXTERNAL_PORT=8084
NGINX_EXTERNAL_PORT=8080

# PostgreSQL tuning
POSTGRES_MAX_CONNECTIONS=320
POSTGRES_SHARED_BUFFERS=512MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1536MB
POSTGRES_WORK_MEM=8MB
POSTGRES_MAINTENANCE_WORK_MEM=128MB

# Backup
BACKUP_SCHEDULE=@monthly
BACKUP_KEEP_DAYS=180
BACKUP_SUFFIX=.sql.gz

# Service profiles
EUREKA_SERVER_PROFILE=default
USERS_SERVICE_PROFILE=prod
METHODOLOGIES_SERVICE_PROFILE=prod
TESTS_SERVICE_PROFILE=prod
ATTEMPTS_SERVICE_PROFILE=prod

# Integrations
REDIS_HOST=redis
REDIS_PORT=6379
EUREKA_DEFAULT_ZONE=http://eureka-server:8761/eureka

# Security / access
TOKEN_SIGNING_KEY=replace_with_base64_secret_key
CORS_ALLOWED_ORIGINS=http://localhost:3000
ADMIN_MAX_SUPER_ADMINS=2

# Users DB pool
USERS_DB_POOL_MAX_SIZE=20
USERS_DB_POOL_MIN_IDLE=5
USERS_DB_POOL_CONNECTION_TIMEOUT=10000
USERS_DB_POOL_IDLE_TIMEOUT=30000
USERS_DB_POOL_MAX_LIFETIME=900000

# Methodologies DB pool
METHODOLOGIES_DB_POOL_MAX_SIZE=20
METHODOLOGIES_DB_POOL_MIN_IDLE=5
METHODOLOGIES_DB_POOL_CONNECTION_TIMEOUT=10000
METHODOLOGIES_DB_POOL_IDLE_TIMEOUT=30000
METHODOLOGIES_DB_POOL_MAX_LIFETIME=900000

# Tests DB pool
TESTS_DB_POOL_MAX_SIZE=220
TESTS_DB_POOL_MIN_IDLE=20
TESTS_DB_POOL_CONNECTION_TIMEOUT=10000
TESTS_DB_POOL_IDLE_TIMEOUT=30000
TESTS_DB_POOL_MAX_LIFETIME=900000

# Attempts DB pool
ATTEMPTS_DB_POOL_MAX_SIZE=20
ATTEMPTS_DB_POOL_MIN_IDLE=5
ATTEMPTS_DB_POOL_CONNECTION_TIMEOUT=10000
ATTEMPTS_DB_POOL_IDLE_TIMEOUT=30000
ATTEMPTS_DB_POOL_MAX_LIFETIME=900000

# Tests-service Tomcat tuning
TESTS_TOMCAT_THREADS_MAX=800
TESTS_TOMCAT_ACCEPT_COUNT=1000
TESTS_TOMCAT_MAX_CONNECTIONS=20000
